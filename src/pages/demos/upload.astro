---
import Layout from "../../layouts/Layout.astro";
import type { Layout } from "lucide-react";
import UploadManager from "../../components/demos/upload/UploadManager";
import "../../styles/global.css";
---

<Layout
    title="异步上传组件演示"
    description="一个使用 React 和自定义 Hook 构建的高并发文件上传管理器演示。"
>
    <main class="min-h-screen pt-24 pb-16 px-4 bg-zinc-50 dark:bg-zinc-950">
        <div class="max-w-3xl mx-auto mb-10 text-center">
            <h1
                class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-3"
            >
                多文件异步并发上传
            </h1>
            <p
                class="text-sm text-zinc-500 dark:text-zinc-400 max-w-lg mx-auto leading-relaxed"
            >
                一个使用 React 和自定义 Hook 构建的高并发文件上传管理器演示。
                默认在模拟环境中运行，最大并发数限制为 3。
            </p>
        </div>

        <UploadManager client:load />
    </main>
</Layout>
