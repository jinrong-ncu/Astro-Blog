---
import Layout from "../layouts/Layout.astro";
import {
    Github,
    Mail,
    Monitor,
    Coffee,
    Zap,
    Camera,
    Smartphone,
    Code2,
    Server,
} from "lucide-react";
import {
    AUTHOR_NAME,
    AUTHOR_EN,
    AUTHOR_GITHUB,
    AUTHOR_EMAIL,
    AUTHOR_ZHIHU,
} from "../consts";
import "../styles/global.css";
---

<Layout title={`关于我 - ${AUTHOR_NAME}`}>
    <div class="max-w-5xl mx-auto px-4 md:px-6 py-12 md:py-20 animate-fade-in">
        
        <!-- Bento Grid Container -->
        <div grid="~ cols-1 md:cols-3 lg:cols-4 flow-dense" class="gap-4 md:gap-6">
            
            <!-- Module A: Profile (2x2) -->
            <div class="glass-card md:col-span-2 lg:col-span-2 row-span-2 rounded-3xl p-8 md:p-10 flex flex-col justify-between">
                <div class="space-y-4">
                    <div class="w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden border-2 border-white/20 dark:border-white/10 shadow-lg">
                        <img src={`https://github.com/${AUTHOR_GITHUB}.png`} alt={AUTHOR_NAME} class="w-full h-full object-cover" />
                    </div>
                    <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-white">
                        Hi, 我是{AUTHOR_NAME} <span class="animate-bounce inline-block origin-bottom-right">👋</span>
                    </h1>
                    <h2 class="text-lg md:text-xl font-medium text-zinc-600 dark:text-zinc-300">
                        前端开发工程师 / Vibe Coder
                    </h2>
                </div>
                <div class="mt-8">
                    <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed max-w-md">
                        坐标上海。热爱代码、设计与未来。比起单纯地实现功能，我更在意像素级的极致体验与微交互的物理阻尼感。
                    </p>
                </div>
            </div>

            <!-- Module B: Tech Stack (2x1) -->
            <div class="glass-card md:col-span-2 lg:col-span-2 row-span-1 rounded-3xl p-8 flex flex-col justify-center overflow-hidden">
                <h3 class="text-sm font-semibold text-zinc-400 tracking-widest uppercase mb-6 flex items-center gap-2">
                    <Code2 className="w-4 h-4" /> Tech Stack
                </h3>
                <!-- 水平滚动容器 -->
                <div class="flex items-center gap-4 md:gap-6 overflow-x-auto pb-2 scrollbar-hide">
                    {/* 使用 UnoCSS preset-icons 图标，或者随便画个带首字母的色块兜底 */}
                    <div class="w-14 h-14 shrink-0 rounded-2xl bg-white/50 dark:bg-white/5 flex items-center justify-center border border-zinc-200/50 dark:border-white/5 shadow-sm hover:scale-110 transition-transform duration-300 ease-[cubic-bezier(0.25,0.8,0.25,1)]">
                        <div class="text-2xl font-bold text-sky-500">Re</div>
                    </div>
                    <div class="w-14 h-14 shrink-0 rounded-2xl bg-white/50 dark:bg-white/5 flex items-center justify-center border border-zinc-200/50 dark:border-white/5 shadow-sm hover:scale-110 transition-transform duration-300 ease-[cubic-bezier(0.25,0.8,0.25,1)]">
                        <div class="text-2xl font-bold text-emerald-500">Vue</div>
                    </div>
                    <div class="w-14 h-14 shrink-0 rounded-2xl bg-white/50 dark:bg-white/5 flex items-center justify-center border border-zinc-200/50 dark:border-white/5 shadow-sm hover:scale-110 transition-transform duration-300 ease-[cubic-bezier(0.25,0.8,0.25,1)]">
                        <div class="text-2xl font-bold text-blue-600">TS</div>
                    </div>
                    <div class="w-14 h-14 shrink-0 rounded-2xl bg-white/50 dark:bg-white/5 flex items-center justify-center border border-zinc-200/50 dark:border-white/5 shadow-sm hover:scale-110 transition-transform duration-300 ease-[cubic-bezier(0.25,0.8,0.25,1)]">
                        <div class="text-2xl font-bold text-green-600">Node</div>
                    </div>
                    <div class="w-14 h-14 shrink-0 rounded-2xl bg-white/50 dark:bg-white/5 flex items-center justify-center border border-zinc-200/50 dark:border-white/5 shadow-sm hover:scale-110 transition-transform duration-300 ease-[cubic-bezier(0.25,0.8,0.25,1)]">
                        <div class="text-2xl font-bold text-orange-600">Ast</div>
                    </div>
                    <div class="w-14 h-14 shrink-0 rounded-2xl bg-white/50 dark:bg-white/5 flex items-center justify-center border border-zinc-200/50 dark:border-white/5 shadow-sm hover:scale-110 transition-transform duration-300 ease-[cubic-bezier(0.25,0.8,0.25,1)]">
                        <Monitor className="w-6 h-6 text-zinc-700 dark:text-zinc-300" />
                    </div>
                </div>
            </div>

            <!-- Module C: Gear & Life (1x1) -->
            <div class="glass-card md:col-span-1 lg:col-span-1 row-span-1 rounded-3xl relative overflow-hidden group min-h-[220px]">
                <!-- 预留背景图：这里先用渐变代替 -->
                <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/20 to-purple-500/20 group-hover:scale-110 group-hover:saturate-150 transition-all duration-700 ease-[cubic-bezier(0.25,0.8,0.25,1)]"></div>
                
                <div class="absolute inset-x-0 bottom-0 p-4 bg-white/30 dark:bg-black/30 backdrop-blur-xl border-t border-white/20 dark:border-white/10">
                    <p class="text-sm font-medium text-zinc-900 dark:text-white flex items-center gap-2">
                        <Camera className="w-4 h-4" />
                        Photography & Vlog
                    </p>
                </div>
            </div>

            <!-- Module D: Side Quests (1x1) -->
            <div class="glass-card md:col-span-1 lg:col-span-1 row-span-1 rounded-3xl p-6 flex flex-col justify-between min-h-[220px]">
                <div class="w-12 h-12 rounded-xl bg-orange-500/10 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-500 ease-[cubic-bezier(0.25,0.8,0.25,1)]">
                    <Zap className="w-6 h-6 text-orange-500" />
                </div>
                <div>
                    <h3 class="text-xl font-bold text-zinc-900 dark:text-white mb-2">Side Quests</h3>
                    <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
                        折腾日常，搞点好玩的开源组件和小程序。
                    </p>
                </div>
            </div>

        </div>
    </div>
</Layout>

<style>
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    .animate-fade-in {
        animation: fadeIn 0.8s ease-out forwards;
    }
</style>
