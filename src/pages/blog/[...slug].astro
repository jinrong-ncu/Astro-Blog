---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import Comments from "../../components/Comments.astro";
import { AUTHOR_NAME, SITE_TITLE } from "../../consts";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post) => !post.data.draft);
  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const articleUrl = new URL(`/blog/${entry.slug}/`, Astro.site || "https://liujinrong.cn").href;
const imageUrl = new URL(`/og/${entry.slug}.png`, Astro.site || "https://liujinrong.cn").href;
const relatedPosts = posts
  .filter((post) => post.slug !== entry.slug)
  .map((post) => ({
    post,
    score: post.data.tags.filter((tag) => entry.data.tags.includes(tag)).length,
  }))
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map(({ post }) => post);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BlogPosting",
      "@id": `${articleUrl}#article`,
      headline: entry.data.title,
      description: entry.data.description,
      image: imageUrl,
      url: articleUrl,
      datePublished: entry.data.pubDate.toISOString(),
      dateModified: entry.data.pubDate.toISOString(),
      inLanguage: "zh-CN",
      keywords: entry.data.tags.join(", "),
      author: {
        "@type": "Person",
        name: entry.data.author || AUTHOR_NAME,
      },
      publisher: {
        "@type": "Person",
        name: AUTHOR_NAME,
      },
      isPartOf: {
        "@type": "Blog",
        name: SITE_TITLE,
        url: new URL("/", Astro.site || "https://liujinrong.cn").href,
      },
      mainEntityOfPage: {
        "@type": "WebPage",
        "@id": articleUrl,
      },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${articleUrl}#breadcrumb`,
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "首页",
          item: new URL("/", Astro.site || "https://liujinrong.cn").href,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: entry.data.title,
          item: articleUrl,
        },
      ],
    },
  ],
};
---

<Layout
  title={entry.data.title}
  description={entry.data.description}
  type="article"
  canonical={articleUrl}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl pb-20 pt-4 sm:pt-8">
    <header class="mb-10 text-center sm:mb-12">
      <div class="mx-auto mb-5 flex max-w-3xl flex-wrap justify-center gap-2 sm:mb-6">
        {
          entry.data.tags.map((tag) => (
            <a
              href={`/tags/${tag}`}
              class="inline-flex items-center rounded-full bg-zinc-100 px-3 py-1 text-xs font-medium text-zinc-600 transition-colors hover:bg-zinc-200 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700"
            >
              {tag}
            </a>
          ))
        }
      </div>

      <h1
        class="mx-auto max-w-3xl text-balance text-3xl font-bold leading-tight tracking-tight text-zinc-900 dark:text-white sm:text-4xl md:text-[2.75rem]"
        transition:name={`title-${entry.slug}`}
      >
        {entry.data.title}
      </h1>

      <div
        class="mt-5 flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-sm text-zinc-500 dark:text-zinc-400"
      >
        <time
          >{
            entry.data.pubDate.toLocaleDateString("zh-CN", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }</time
        >
        <span>·</span>
        <span>{entry.data.author}</span>
        <span>·</span>
        <span
          id="busuanzi_container_page_pv"
          class="hidden items-center gap-1 text-sm text-zinc-500 dark:text-zinc-400"
          style="display: none;"
        >
          <span id="busuanzi_value_page_pv">Loading...</span> 次阅读
        </span>
      </div>
    </header>

    <div
      class="prose prose-zinc mx-auto max-w-none prose-base prose-headings:font-bold prose-a:text-blue-600 hover:prose-a:text-blue-500 dark:prose-invert dark:prose-a:text-blue-400 sm:prose-lg"
    >
      <Content />
    </div>

    {
      relatedPosts.length > 0 && (
        <aside class="mt-16 border-t border-zinc-200/70 pt-8 dark:border-zinc-800/80">
          <h2 class="text-xl font-bold text-zinc-900 dark:text-zinc-50">
            继续阅读
          </h2>
          <div class="mt-5 grid gap-4 sm:grid-cols-3">
            {relatedPosts.map((post) => (
              <a
                href={`/blog/${post.slug}/`}
                class="group rounded-lg border border-zinc-200/80 bg-white/60 p-4 transition-colors hover:border-zinc-300 hover:bg-white dark:border-white/10 dark:bg-zinc-900/50 dark:hover:border-white/20 dark:hover:bg-zinc-900"
              >
                <time
                  datetime={post.data.pubDate.toISOString()}
                  class="text-xs font-medium text-zinc-400"
                >
                  {post.data.pubDate.toLocaleDateString("zh-CN", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
                <h3 class="mt-2 text-sm font-bold leading-snug text-zinc-900 group-hover:text-blue-600 dark:text-zinc-100 dark:group-hover:text-blue-300">
                  {post.data.title}
                </h3>
                <p class="mt-2 line-clamp-2 text-xs leading-relaxed text-zinc-500 dark:text-zinc-400">
                  {post.data.description}
                </p>
              </a>
            ))}
          </div>
        </aside>
      )
    }
  </article>
  <Comments />

  <script>
    import mediumZoom from "medium-zoom";

    document.addEventListener("astro:page-load", () => {
      const images = document.querySelectorAll(".prose img");

      images.forEach((img) => {
        if (!img.getAttribute("loading")) {
          img.setAttribute("loading", "lazy");
        }
        if (!img.getAttribute("decoding")) {
          img.setAttribute("decoding", "async");
        }
      });

      mediumZoom(".prose img", {
        background: "rgba(10, 10, 10, 0.85)",
        margin: 24,
      });
    });
  </script>
</Layout>
