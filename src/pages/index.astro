---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import { getCollection } from "astro:content";
import { Typewriter } from "../components/Typewriter";
import PostCard from "../components/PostCard.astro";
import { AUTHOR_NAME } from "../consts";

// const posts = (await getCollection("blog")).sort(
//   (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
// );

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort(
    (a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

const pageSize = 9;
const featuredPost = posts.find((post) => post.data.featured);
const regularPosts = featuredPost
  ? posts.filter((post) => post.slug !== featuredPost.slug)
  : posts;
const pagePosts = regularPosts.slice(0, pageSize);
const hiddenPosts = regularPosts.slice(pageSize);
---

<Layout
  title={`${AUTHOR_NAME} Blog`}
  description="荣十一的个人博客，记录全栈开发、AI 工具、个人网站、学生资源、效率工作流与产品思考，分享真实项目中的技术实践和学习笔记。"
>
  <div class="animate-fade-in">
    <section
      class="relative z-10 mx-auto max-w-5xl px-1 pb-10 pt-6 sm:px-6 sm:pb-12 sm:pt-10"
    >
      <div class="space-y-2 relative max-w-3xl">
        <div class="h-8 sm:h-10 flex items-center">
          <p
            class="text-xl sm:text-2xl text-zinc-600 dark:text-zinc-300 font-mono"
          >
            <Typewriter
              client:visible
              text={["书写设计、代码与未来。"]}
              speed={200}
              waitTime={2000}
              deleteSpeed={100}
              cursorChar="|"
            />
          </p>
        </div>
      </div>
    </section>

    <style>
      /* Intentionally empty for now, removed mask-gradient */
    </style>

    <section class="space-y-12 relative z-10">
      {
        featuredPost && (
          <a
            href={`/blog/${featuredPost.slug}/`}
            class="group relative block overflow-hidden rounded-2xl border border-zinc-200/75 bg-white/60 p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.78),0_18px_60px_-46px_rgba(24,24,27,0.5)] backdrop-blur-2xl transition-all hover:-translate-y-1 hover:border-zinc-300 hover:bg-white/75 dark:border-white/10 dark:bg-zinc-950/50 dark:shadow-[inset_0_1px_0_rgba(255,255,255,0.08),0_28px_90px_-60px_rgba(0,0,0,0.95)] dark:hover:border-white/20 dark:hover:bg-zinc-900/65 sm:rounded-3xl sm:p-6 md:p-8"
          >
            <div class="pointer-events-none absolute inset-y-0 right-0 hidden w-1/3 bg-gradient-to-l from-sky-200/45 via-cyan-100/20 to-transparent dark:from-sky-900/18 md:block" />

            <div class="relative grid gap-6 lg:grid-cols-[minmax(0,1.35fr)_minmax(260px,0.65fr)] lg:items-end">
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <span class="rounded-full bg-zinc-900 px-3 py-1 text-xs font-bold text-white dark:bg-white dark:text-zinc-950">
                    精选
                  </span>
                  <time
                    datetime={featuredPost.data.pubDate.toISOString()}
                    class="text-xs font-semibold text-zinc-400"
                  >
                    {featuredPost.data.pubDate.toLocaleDateString("zh-CN", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </div>

                <h2 class="mt-5 max-w-3xl text-2xl font-extrabold leading-tight tracking-tight text-zinc-950 transition-colors group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-300 sm:text-3xl md:text-4xl">
                  {featuredPost.data.title}
                </h2>
                <p class="mt-3 max-w-2xl text-sm leading-relaxed text-zinc-600 dark:text-zinc-400 sm:mt-4 sm:text-base">
                  {featuredPost.data.description}
                </p>
              </div>

              <div class="hidden rounded-2xl border border-zinc-200/70 bg-white/55 p-4 backdrop-blur-xl dark:border-white/10 dark:bg-zinc-900/45 sm:block">
                <div class="text-xs font-bold uppercase tracking-[0.1em] text-zinc-400">
                  Why read
                </div>
                <p class="mt-2 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
                  一篇适合学生收藏的权益索引，能顺手串起
                  AI、开发、设计和云服务工具。
                </p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {featuredPost.data.tags.slice(0, 5).map((tag) => (
                    <span class="rounded-md bg-zinc-100 px-2 py-1 text-xs font-medium text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        )
      }

      <div id="post-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {pagePosts.map((post) => <PostCard post={post} />)}
        {
          hiddenPosts.map((post) => (
            <div class="hidden post-extra">
              <PostCard post={post} />
            </div>
          ))
        }
      </div>
      {
        hiddenPosts.length > 0 && (
          <div class="flex justify-center">
            <button
              id="load-more-posts"
              type="button"
              data-page-size={pageSize}
              class="rounded-full border border-zinc-200/80 bg-white/50 px-5 py-2.5 text-sm font-bold text-zinc-600 backdrop-blur-xl transition-colors hover:border-zinc-300 hover:bg-white hover:text-zinc-900 dark:border-white/10 dark:bg-zinc-950/40 dark:text-zinc-300 dark:hover:border-white/20 dark:hover:bg-zinc-900"
            >
              加载更多文章
            </button>
          </div>
        )
      }
    </section>

    <script>
      const initLoadMorePosts = () => {
        const button = document.getElementById("load-more-posts");
        const extras = Array.from(document.querySelectorAll(".post-extra"));

        if (!button || extras.length === 0) return;
        if (button.dataset.initialized === "true") return;

        button.dataset.initialized = "true";

        const pageSize = Number(button.dataset.pageSize || 9);
        let visibleCount = 0;

        const revealMore = () => {
          const nextItems = extras.slice(visibleCount, visibleCount + pageSize);

          nextItems.forEach((item) => {
            item.classList.remove("hidden");
          });

          visibleCount += nextItems.length;

          if (visibleCount >= extras.length) {
            button.remove();
          }
        };

        button.addEventListener("click", revealMore);
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initLoadMorePosts, {
          once: true,
        });
      } else {
        initLoadMorePosts();
      }

      document.addEventListener("astro:page-load", initLoadMorePosts);
    </script>
  </div>
</Layout>
