      { name: "GitHub", desc: "代码托管、项目展示和协作", icon: Code2 },
      { name: "Vercel", desc: "前端项目和静态站点部署", icon: Globe },
      { name: "Cloudflare", desc: "DNS、Pages、Workers 和 CDN", icon: Globe },
      { name: "Supabase", desc: "Postgres、Auth 和轻量后端", icon: Database },
      { name: "Cloudflare R2", desc: "对象存储和静态资源托管", icon: Database },
      {
        name: "iCloud Drive",
        desc: "桌面文件和 Apple 设备同步",
        icon: FolderSync,
      },
      { name: "OneDrive", desc: "文档、课程资料和备份", icon: FolderSync },
    ],
  },
  {
    category: "浏览与信息流 (Research)",
    icon: Globe,
    list: [
      { name: "Arc", desc: "Spaces 管理不同项目上下文", icon: Globe },
      {
        name: "Chrome DevTools",
        desc: "前端调试、性能和网络面板",
        icon: Code2,
      },
      { name: "Safari", desc: "WebKit 兼容性和 Apple 端检查", icon: Globe },
      { name: "RSS", desc: "博客、技术站和产品更新订阅", icon: BookOpen },
      { name: "GitHub Trending", desc: "开源项目观察和技术雷达", icon: Search },
      { name: "Product Hunt", desc: "产品灵感和工具趋势观察", icon: Search },
    ],
  },
];

const lastUpdated = "Jun 2026";
---

<Layout
  title={`Uses - ${AUTHOR_NAME}`}
  description={`${AUTHOR_NAME} 的硬件、开发环境、AI agents、效率工具、笔记写作和云服务清单。`}
>
  <div class="max-w-5xl mx-auto px-6 py-12 md:py-20 animate-fade-in">
    <div class="mb-16">
      <h1 class="text-4xl font-bold mb-6 text-zinc-900 dark:text-white">
        Uses
      </h1>
      <p
        class="text-zinc-500 dark:text-zinc-400 text-lg max-w-3xl leading-relaxed"
      >
        工具会变，但工作流会留下来。这里整理我日常开发、写作、学习、AI
        协作和内容创作里常用的硬件与软件。
      </p>
      <div
        class="mt-6 mb-6 inline-flex items-center text-xs font-medium px-2.5 py-0.5 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400"
      >
        Last Updated: {lastUpdated}
      </div>
    </div>

    <div class="space-y-16">
      {
        items.map((section) => (
          <section class="mb-8">
            <h2 class="text-2xl font-bold mb-4 flex items-center gap-3 text-zinc-900 dark:text-zinc-100 pb-4 border-b border-zinc-100 dark:border-zinc-800">
              <section.icon className="w-6 h-6" />
              {section.category}
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {section.list.map((item) => (
                <div class="p-5 rounded-lg border border-zinc-200/60 dark:border-zinc-800/60 bg-white/70 dark:bg-zinc-900/50 hover:border-zinc-300 dark:hover:border-zinc-700 transition-colors group">
                  <div class="flex items-start gap-4">
                    <div class="p-2.5 rounded-lg bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-zinc-100 transition-colors">
                      <item.icon className="w-5 h-5" />
                    </div>
                    <div class="min-w-0">
                      <h3 class="font-bold text-zinc-900 dark:text-zinc-100 text-lg mb-1">
                        {item.name}
                      </h3>
                      <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
                        {item.desc}
                      </p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</Layout>
