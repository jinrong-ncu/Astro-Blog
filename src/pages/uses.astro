      {
        name: "HHKB Professional Hybrid",
        desc: "Type-S / 静电容",
        icon: Keyboard,
      },
      {
        name: "Magic Trackpad",
        desc: "手势、窗口切换和轻量浏览",
        icon: MousePointer2,
      },
    ],
  },
  {
    category: "开发环境 (Dev Stack)",
    icon: Code2,
    list: [
      {
        name: "VS Code",
        desc: "Theme: Vercel Dark / Font: JetBrains Mono",
        icon: Code2,
      },
      {
        name: "Cursor",
        desc: "AI IDE，适合多文件理解和快速改稿",
        icon: Bot,
      },
      {
        name: "Windsurf",
        desc: "Agentic IDE，适合连续上下文开发",
        icon: PanelsTopLeft,
      },
      { name: "Warp", desc: "Rust-based Terminal / Zsh", icon: Terminal },
      { name: "iTerm2", desc: "稳定备用终端与 SSH 会话", icon: Terminal },
      {
        name: "Arc Browser",
        desc: "主力浏览器与工作区管理",
        icon: Globe,
      },
      {
        name: "Chrome",
        desc: "调试、兼容性测试和扩展生态",
        icon: Globe,
      },
      {
        name: "Postman",
        desc: "API 调试、集合管理和接口验证",
        icon: Network,
      },
      {
        name: "TablePlus",
        desc: "数据库连接、查询和轻量管理",
        icon: Database,
      },
    ],
  },
  {
    category: "AI Agents / Coding Assistants",
    icon: Bot,
    list: [
      {
        name: "Codex",
        desc: "OpenAI coding agent，适合仓库级任务和代码审查",
        icon: Bot,
      },
      {
        name: "Claude Code",
        desc: "终端里的 agentic coding system，适合重构和测试迭代",
        icon: Terminal,
      },
      {
