    category: "效率神器 (Productivity)",
    icon: Zap,
    list: [
      { name: "Raycast", desc: "启动器与快捷操作中心", icon: Zap },
      { name: "uTools", desc: "插件化效率工具和本地小组件", icon: Layers },
      { name: "Bob", desc: "划词翻译、OCR 和多引擎翻译", icon: Search },
      { name: "CleanShot X", desc: "截图、标注与录屏工具", icon: Camera },
