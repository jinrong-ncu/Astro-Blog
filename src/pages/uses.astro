---
import Layout from "../layouts/Layout.astro";
import {
  Bot,
  BookOpen,
  Brain,
  Brush,
  Cable,
  Monitor,
  Cpu,
  Database,
  FileText,
  FolderSync,
  GitBranch,
  Keyboard,
  Code2,
  Layers,
  MessageSquareText,
  MousePointer2,
  Network,
  NotebookPen,
  PanelsTopLeft,
  PencilRuler,
  Search,
  ShieldCheck,
  Terminal,
  Globe,
  Zap,
  Battery,
  Download,
  Camera,
} from "lucide-react";
import { AUTHOR_NAME } from "../consts";
import "../styles/global.css";

const items = [
