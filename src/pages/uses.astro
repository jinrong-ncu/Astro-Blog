    category: "核心装备 (Workstation)",
    icon: Monitor,
    list: [
      { name: 'MacBook Pro 16"', desc: "M2 Max / 64GB / 8TB", icon: Cpu },
      {
        name: "LG 27UP850",
        desc: "4K Display / Type-C 96W",
