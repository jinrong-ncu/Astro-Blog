---
import { SITE_TITLE, AUTHOR } from "../consts";
import { Github, Twitter, Rss, Mail } from "lucide-react";

const today = new Date();
---

<footer
    class="mt-20 mb-8 mx-auto w-full max-w-4xl px-4 relative z-10 transition-colors"
>
    <div
        class="liquid-vessel rounded-[2.5rem] p-6 lg:px-8 lg:py-6 flex flex-col md:flex-row justify-between items-center gap-6"
    >
        <!-- Left: Status and Copyright -->
        <div class="flex flex-col items-center md:items-start gap-2.5">
            <div
                class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/40 dark:bg-black/20 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.4)] dark:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05)] w-fit backdrop-blur-md"
            >
                <span class="relative flex h-2 w-2">
                    <span
                        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
                    ></span>
                    <span
                        class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
                    ></span>
                </span>
                <span
                    class="text-[11px] font-semibold tracking-wide uppercase text-zinc-600 dark:text-zinc-400"
                >
                    Coding in Shanghai
                </span>
            </div>

            <p
                class="text-[13px] text-zinc-500 dark:text-zinc-400 font-medium tracking-tight"
            >
                &copy; {today.getFullYear()}
                {AUTHOR}. All rights reserved.
            </p>

            <div
                class="flex items-center gap-2 text-[11px] text-zinc-400 dark:text-zinc-500 font-medium tracking-tight"
                id="busuanzi_container_site_pv"
                style="display: none;"
            >
                <span
                    class="hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors"
                    >访问量 <span
                        id="busuanzi_value_site_pv"
                        class="font-semibold text-zinc-500 dark:text-zinc-400"
                    ></span> 次</span
                >
                <span
                    class="w-[3px] h-[3px] rounded-full bg-zinc-300 dark:bg-zinc-700"
                ></span>
                <span
                    class="hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors"
                    >Astro & Tailwind CSS</span
                >
            </div>
        </div>

        <!-- Right: Social & Links (Micro-Droplets) -->
        <div class="flex flex-col sm:flex-row items-center gap-4">
            <!-- Text Links -->
            <div
                class="flex items-center gap-1.5 px-4 py-2 rounded-full bg-white/30 dark:bg-black/20 shadow-[inset_0_1px_0_0_rgba(255,255,255,0.3)] dark:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05)] backdrop-blur-sm"
            >
                <a
                    href="/about"
                    class="micro-droplet-text text-[13px] font-semibold text-zinc-600 dark:text-zinc-400 px-2.5 py-1 tracking-tight"
                    >关于</a
                >
                <span class="text-zinc-300 dark:text-zinc-700 font-light"
                    >/</span
                >
                <a
                    href="mailto:jinrong.liu@email.ncu.edu.cn"
                    class="micro-droplet-text text-[13px] font-semibold text-zinc-600 dark:text-zinc-400 px-2.5 py-1 tracking-tight"
                    >联系</a
                >
            </div>

            <!-- Social Icons -->
            <div
                class="flex items-center gap-1 bg-white/30 dark:bg-black/20 p-1 rounded-full shadow-[inset_0_1px_0_0_rgba(255,255,255,0.3)] dark:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.05)] backdrop-blur-sm"
            >
                <a
                    href="https://github.com/jinrong-ncu"
                    target="_blank"
                    aria-label="GitHub"
                    class="micro-droplet text-zinc-500 dark:text-zinc-400"
                >
                    <Github size={16} strokeWidth={2.5} />
                </a>
                <a
                    href="https://x.com/liujinrong"
                    target="_blank"
                    aria-label="Twitter"
                    class="micro-droplet text-zinc-500 dark:text-zinc-400"
                >
                    <Twitter size={16} strokeWidth={2.5} />
                </a>
                <a
                    href="/rss.xml"
                    target="_blank"
                    aria-label="RSS"
                    class="micro-droplet text-zinc-500 dark:text-zinc-400"
                >
                    <Rss size={16} strokeWidth={2.5} />
                </a>
                <a
                    href="mailto:jinrong.liu@email.ncu.edu.cn"
                    aria-label="Email"
                    class="micro-droplet text-zinc-500 dark:text-zinc-400"
                >
                    <Mail size={16} strokeWidth={2.5} />
                </a>
            </div>
        </div>
    </div>
</footer>

<style>
    /* Base Container Styles */
    .liquid-vessel {
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.5) 0%,
            rgba(255, 255, 255, 0.1) 100%
        );
        backdrop-filter: blur(28px) saturate(210%);
        -webkit-backdrop-filter: blur(28px) saturate(210%);
        box-shadow:
            0 8px 32px rgba(0, 0, 0, 0.04),
            0 1px 2px rgba(0, 0, 0, 0.01),
            inset 0 1px 0 0 rgba(255, 255, 255, 0.6),
            inset 0 0 0 1px rgba(255, 255, 255, 0.2);
        transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    :global(.dark) .liquid-vessel {
        background: linear-gradient(
            135deg,
            rgba(40, 40, 40, 0.4) 0%,
            rgba(10, 10, 10, 0.6) 100%
        );
        box-shadow:
            0 8px 32px rgba(0, 0, 0, 0.4),
            0 1px 2px rgba(0, 0, 0, 0.2),
            inset 0 1px 0 0 rgba(255, 255, 255, 0.1),
            inset 0 0 0 1px rgba(255, 255, 255, 0.02);
    }

    /* Hover float effect on the entire vessel */
    .liquid-vessel:hover {
        transform: translateY(-4px);
        box-shadow:
            0 12px 40px rgba(0, 0, 0, 0.06),
            0 4px 12px rgba(0, 0, 0, 0.02),
            inset 0 1px 0 0 rgba(255, 255, 255, 0.7),
            inset 0 0 0 1px rgba(255, 255, 255, 0.3);
    }

    :global(.dark) .liquid-vessel:hover {
        box-shadow:
            0 12px 40px rgba(0, 0, 0, 0.5),
            0 4px 12px rgba(0, 0, 0, 0.3),
            inset 0 1px 0 0 rgba(255, 255, 255, 0.15),
            inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    }

    /* ========================================= */
    /* Micro-Droplet Icon Interactions           */
    /* ========================================= */
    .micro-droplet {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 50%;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        z-index: 1;
    }

    /* The hidden glowing blob that expands on hover */
    .micro-droplet::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: radial-gradient(
            circle at center,
            rgba(0, 0, 0, 0.06) 0%,
            rgba(0, 0, 0, 0) 70%
        );
        opacity: 0;
        transform: scale(0.5);
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        z-index: -1;
    }

    :global(.dark) .micro-droplet::before {
        background: radial-gradient(
            circle at center,
            rgba(255, 255, 255, 0.15) 0%,
            rgba(255, 255, 255, 0) 70%
        );
    }

    .micro-droplet:hover {
        transform: scale(1.15);
        color: #18181b; /* strict selection to zinc-900 */
    }

    :global(.dark) .micro-droplet:hover {
        color: #ffffff;
    }

    .micro-droplet:hover::before {
        opacity: 1;
        transform: scale(1.3);
    }

    .micro-droplet:active {
        transform: scale(0.95);
    }

    /* ========================================= */
    /* Micro-Droplet Text Interactions           */
    /* ========================================= */
    .micro-droplet-text {
        position: relative;
        border-radius: 10px;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        z-index: 1;
    }

    /* Hidden pill background that expands */
    .micro-droplet-text::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 10px;
        background: rgba(0, 0, 0, 0.04);
        opacity: 0;
        transform: scale(0.85);
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        z-index: -1;
    }

    :global(.dark) .micro-droplet-text::before {
        background: rgba(255, 255, 255, 0.1);
    }

    .micro-droplet-text:hover {
        transform: scale(1.05);
        color: #18181b;
    }

    :global(.dark) .micro-droplet-text:hover {
        color: #ffffff;
    }

    .micro-droplet-text:hover::before {
        opacity: 1;
        transform: scale(1);
    }

    .micro-droplet-text:active {
        transform: scale(0.95);
    }
</style>
