---
const { post, activeTag } = Astro.props;
---

<a
  href={`/blog/${post.slug}/`}
  class="group glass-card flex flex-col gap-3 rounded-3xl p-6"
>
  <div class="mb-2 flex items-center gap-3 text-xs font-medium text-zinc-400">
    <time datetime={post.data.pubDate.toISOString()}>
      {
        post.data.pubDate.toLocaleDateString("zh-CN", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })
      }
    </time>
  </div>

  <h2
    class="text-xl font-semibold tracking-tight text-zinc-900 transition-colors group-hover:text-black dark:text-white dark:group-hover:text-white"
    transition:name={`title-${post.slug}`}
  >
    {post.data.title}
  </h2>

  <p class="line-clamp-2 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
    {post.data.description}
  </p>

  <div class="mt-auto flex flex-wrap gap-2 pt-4">
    {
      post.data.tags.map((tag) => (
        <span
          class={`glass-tag inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ${
            tag === activeTag
              ? "text-zinc-900 dark:text-zinc-100"
              : "text-zinc-600 dark:text-zinc-300"
          }`}
        >
          {tag}
        </span>
      ))
    }
  </div>
</a>
